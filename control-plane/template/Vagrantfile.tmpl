# Auto-generated Honeypot Infrastructure
# Generated: {{ .Timestamp.Format "2006-01-02 15:04:05" }}
# Topology: {{ .Topology.Name }}

Vagrant.configure("2") do |config|
  # Global settings
  config.vm.provider "virtualbox" do |vb|
    vb.linked_clone = true
  end

  {{range .Configs}}
  # Honeypot: {{ .Name }}
  config.vm.define "{{ .Name }}" do |hp|
    hp.vm.box = "{{ .VagrantBox }}"
    hp.vm.hostname = "{{ .Name }}"
    
    # Network configuration
    hp.vm.network "private_network", 
      ip: "{{ .IP }}",
      virtualbox__intnet: "honeynet_{{ .NetworkTier }}",
      libvirt__network_name: "honeynet_{{ .NetworkTier }}",
      libvirt__dhcp_enabled: false
    
    # Resources
    hp.vm.provider "virtualbox" do |vb|
      vb.name = "{{ .Name }}"
      vb.memory = {{ .MemoryMB }}
      vb.cpus = {{ .CPUCores }}
      vb.customize ["modifyvm", :id, "--nicpromisc2", "allow-all"]
      vb.customize ["modifyvm", :id, "--nictrace2", "on"]
      vb.customize ["modifyvm", :id, "--nictracefile2", "/var/log/honeypot_{{ .Name }}.pcap"]
    end
    
    hp.vm.provider "libvirt" do |lv|
      lv.memory = {{ .MemoryMB }}
      lv.cpus = {{ .CPUCores }}
      lv.storage :file, size: '{{ .DiskGB }}G'
    end
    
    # Install Maya agent (Rust binary)
    hp.vm.provision "file", source: "../agent/target/release/syslogd-helper", destination: "/tmp/syslogd-helper"
    
    hp.vm.provision "shell", inline: <<-SHELL
      install -m 755 /tmp/syslogd-helper /usr/local/bin/
      
      # Configure peers
      mkdir -p /etc/syslogd-helper
      cat > /etc/syslogd-helper/peers.conf << 'EOF'
{{range .Peers}}{{.}}
{{end}}EOF
      
      # Systemd service
      cat > /etc/systemd/system/maya-agent.service << 'EOF'
[Unit]
Description=Maya Honeypot Agent
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/syslogd-helper daemon
Restart=always
Environment="MAYA_NODE_ID={{ .Name }}"

[Install]
WantedBy=multi-user.target
EOF
      
      systemctl daemon-reload
      systemctl enable --now maya-agent
      
      # Install services: {{ join ", " .Services }}
      {{range .Services}}
      /opt/maya/provision-{{ . }}.sh
      {{end}}
    SHELL
  end
  {{end}}
end